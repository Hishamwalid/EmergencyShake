<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="32dp"
    android:background="?android:windowBackground"
    android:gravity="center_horizontal">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reset Password and Security Question"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:textColor="?android:textColorPrimary" />

    <LinearLayout
        android:id="@+id/verifyContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Current Security Question"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:textColor="?android:textColorPrimary" />

        <TextView
            android:id="@+id/tvCurrentQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:gravity="center"
            android:background="@drawable/bg_monochrome_rounded"
            android:textColor="?android:textColorPrimary"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Answer to verify"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:textColor="#000000" />

        <EditText
            android:id="@+id/etAnswer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Your Answer"
            android:inputType="text"
            android:background="@drawable/bg_monochrome_rounded"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:gravity="center"
            android:textColor="?android:textColorPrimary"
            android:textColorHint="?android:textColorHint"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnVerifyAnswer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Verify Answer"
            android:background="@drawable/btn_monochrome_primary"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutNewData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="24dp">

        <!-- ✅ Added buttonTint to make checkbox monochrome -->
        <CheckBox
            android:id="@+id/cbChangePassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Change password"
            android:checked="true"
            android:layout_marginBottom="16dp"
            android:textColor="?android:textColorPrimary"
            android:buttonTint="?android:textColorPrimary" />

        <LinearLayout
            android:id="@+id/layoutPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="New Password"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"
                android:textColor="?android:textColorPrimary" />

            <EditText
                android:id="@+id/etNewPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="New Password (numbers only)"
                android:inputType="numberPassword"
                android:background="@drawable/bg_monochrome_rounded"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:gravity="center"
                android:textColor="?android:textColorPrimary"
                android:textColorHint="?android:textColorHint"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Confirm Password"
                android:inputType="numberPassword"
                android:background="@drawable/bg_monochrome_rounded"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:gravity="center"
                android:textColor="?android:textColorPrimary"
                android:textColorHint="?android:textColorHint"
                android:layout_marginBottom="24dp" />

        </LinearLayout>

        <!-- ✅ Added buttonTint to make checkbox monochrome -->
        <CheckBox
            android:id="@+id/cbChangeQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Change security question"
            android:layout_marginBottom="16dp"
            android:textColor="?android:textColorPrimary"
            android:buttonTint="?android:textColorPrimary" />

        <LinearLayout
            android:id="@+id/layoutChangeQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="New Security Question"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"
                android:textColor="?android:textColorPrimary" />

            <Spinner
                android:id="@+id/spNewQuestions"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_monochrome_rounded"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/etNewCustomQuestion"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Enter custom question"
                android:inputType="text"
                android:background="@drawable/bg_monochrome_rounded"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:gravity="center"
                android:textColor="?android:textColorPrimary"
                android:textColorHint="?android:textColorHint"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <EditText
                android:id="@+id/etNewAnswer"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Answer for new question"
                android:inputType="text"
                android:background="@drawable/bg_monochrome_rounded"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:gravity="center"
                android:textColor="?android:textColorPrimary"
                android:textColorHint="?android:textColorHint"
                android:layout_marginBottom="24dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnSetPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Apply Changes"
            android:background="@drawable/btn_monochrome_primary"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</LinearLayout>