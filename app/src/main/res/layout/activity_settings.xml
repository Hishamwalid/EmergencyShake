<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:windowBackground">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark">

        <ImageButton
            android:id="@+id/btnShakeSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_settings"
            android:background="@android:color/transparent"
            android:scaleType="centerInside"
            android:layout_gravity="end" />
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- Emergency Contacts -->
            <TextView
                android:id="@+id/labelContacts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emergency Contacts"
                android:textStyle="bold"
                android:textColor="?android:textColorPrimary" />

            <LinearLayout
                android:id="@+id/contactsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp" />

            <Button
                android:id="@+id/btnAddContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Add Emergency Contact"
                android:textColor="#000000"
                android:background="@drawable/btn_monochrome_primary"
                android:textAllCaps="false" />

            <!-- Starting point -->
            <Button
                android:id="@+id/btnSetCurrentLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Set Current Location as Starting Point"
                android:textColor="#000000"
                android:background="@drawable/btn_monochrome_primary"
                android:textAllCaps="false" />

            <TextView
                android:id="@+id/tvStartingPoint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Starting point: not set"
                android:textSize="14sp"
                android:textColor="?android:textColorPrimary"
                android:paddingStart="8dp" />

            <!-- Destination -->
            <Button
                android:id="@+id/btnSetDestination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Set Destination"
                android:textColor="#000000"
                android:background="@drawable/btn_monochrome_primary"
                android:textAllCaps="false" />

            <TextView
                android:id="@+id/tvDestination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Destination: not set"
                android:textSize="14sp"
                android:textColor="?android:textColorPrimary"
                android:paddingStart="8dp" />

            <!-- Big round Activate/Deactivate button -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnToggleProtection"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:text="ACTIVATE"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_round_primary"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:elevation="8dp" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Protection inactive"
                android:gravity="center"
                android:textSize="16sp"
                android:layout_marginBottom="24dp"
                android:textColor="?android:textColorPrimary" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>