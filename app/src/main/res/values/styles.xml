<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Calculator number buttons (white background) -->
    <style name="CalcButtonNum">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:textSize">24sp</item>
        <item name="android:background">#FFFFFF</item>
        <item name="android:textColor">#000000</item>
    </style>

    <!-- Calculator operator buttons (orange background) -->
    <style name="CalcButtonOp">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:textSize">24sp</item>
        <item name="android:background">#FF9800</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <!-- Calculator function buttons (gray background: AC, %) -->
    <style name="CalcButtonGray">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:textSize">24sp</item>
        <item name="android:background">#E0E0E0</item>
        <item name="android:textColor">#000000</item>
    </style>
</resources>