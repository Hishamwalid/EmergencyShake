<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView android:text="Emergency Contact" android:textStyle="bold" android:layout_marginTop="16dp"/>
    <EditText android:id="@+id/etContact" android:hint="Phone number" android:inputType="phone" android:layout_marginBottom="8dp"/>
    <Button android:id="@+id/btnSaveContact" android:text="Save Contact"/>
</LinearLayout>